{
  // VS Code「Reopen in Container」でも、CLI の `devcontainer up` でも、
  // 同じこのファイル一枚で起動できる（= 配布フォーマットとして単一の正）。
  "name": "${localWorkspaceFolderBasename}",
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "app",
  "workspaceFolder": "/app",
  "overrideCommand": true,
  "shutdownAction": "stopCompose",
  "containerUser": "root",
  "remoteUser": "appuser",
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-python.vscode-pylance"],
      "settings": { "editor.formatOnSave": true }
    }
  },
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/appuser/.claude",
    "CODEX_CONFIG_DIR": "/home/appuser/.codex",
    "GEMINI_CONFIG_DIR": "/home/appuser/.gemini",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true"
  },

  // 旧: features（Node / Claude Code）と postCreateCommand（npm -g）でツール導入
  // 新: すべて共有イメージ ai-devbox:1.0 に焼き込み済みなので、ここでは何も入れない。
  //     → プロジェクトごとの feature 層の重複（実測 ~870MB/台）が消える。

  // 認証ボリュームは空で起動するため、所有権と権限だけ整える
  "postStartCommand": "sudo mkdir -p $CLAUDE_CONFIG_DIR $CODEX_CONFIG_DIR $GEMINI_CONFIG_DIR && sudo chown -R appuser:appuser $CLAUDE_CONFIG_DIR $CODEX_CONFIG_DIR $GEMINI_CONFIG_DIR && sudo chmod 700 $CLAUDE_CONFIG_DIR $CODEX_CONFIG_DIR"
}
